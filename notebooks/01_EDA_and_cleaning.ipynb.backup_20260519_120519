    "        \n",
    "        optb = OptimalBinning(\n",
    "            name=feature,\n",
    "            dtype='numerical',\n",
    "            max_n_bins=10,\n",
    "            min_bin_size=0.05\n",
    "        )\n",
    "        \n",
    "        optb.fit(x, y_vals)\n",
    "        binning_table = optb.binning_table.build()\n",
    "        iv = binning_table['IV'].iloc[-1]\n",
